{
  "productName": "aimeat-agency",
  "version": "0.8.11",
  "identifier": "io.aimeat.agency",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": { "csp": null },
    "windows": [
      {
        "label": "splash",
        "title": "aimeat-agency",
        "width": 1100,
        "height": 820,
        "minWidth": 900,
        "minHeight": 650,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/uv"],
    "resources": ["resources/runtime-src/**/*"]
  }
}
