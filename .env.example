# =====================================================================
# crewaimeat – ympäristömuuttujat. Kopioi tämä tiedostoksi .env ja täytä.
#   cp .env.example .env        (tai Windows: copy .env.example .env)
# =====================================================================

# --- OpenRouter (pakollinen) -----------------------------------------
# Hae avain: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Malli OpenRouterin muodossa "openrouter/<provider>/<model>".
# Halpoja/nopeita vaihtoehtoja PoC:lle:
#   openrouter/x-ai/grok-4-fast              (halpa, nopea – oletus)
#   openrouter/deepseek/deepseek-chat-v3.1   (erittäin halpa)
#   openrouter/google/gemini-2.0-flash-001   (halpa, nopea)
#   openrouter/openai/gpt-4o-mini            (luotettava, hieman kalliimpi)
OPENROUTER_MODEL=openrouter/x-ai/grok-4-fast
OPENROUTER_FALLBACK_MODELS=   # optional: comma-separated OpenRouter model ids tried IN ORDER if the primary errors (incl. a provider 400; OpenRouter allows MAX 3), e.g. openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,openrouter/owl-alpha
# Multi-provider priority chain (recommended): create llm_providers.json (see llm_providers.example.json).
# When present it OVERRIDES OPENROUTER_MODEL above. Point elsewhere with: LLM_PROVIDERS_FILE=path/to.json

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Vapaaehtoinen: lämpötila (0.0 = deterministinen, 1.0 = luova)
LLM_TEMPERATURE=0.5

# --- Vaihtoehto: xAI suoraan (jätä tyhjäksi jos käytät OpenRouteria) --
# Jos haluat ohittaa OpenRouterin ja kutsua xAI:ta suoraan, aseta:
#   USE_XAI=1
#   XAI_API_KEY=xai-...
#   XAI_MODEL=xai/grok-4-fast
USE_XAI=
XAI_API_KEY=
XAI_MODEL=xai/grok-4-fast

# --- Web-haku: SearXNG (oletus, ilmainen, ei avainta) ----------------
# Agentit hakevat oletuksena itse-hostatusta SearXNG:stä (ei API-avainta, ei kuluja).
# Aseta tämä jos instanssisi ei ole oletusosoitteessa http://localhost:21333.
SEARXNG_URL=http://localhost:21333
# Vaihtoehto: Tavily. Ota käyttöön asettamalla USE_TAVILY=1 + avain (https://app.tavily.com/).
USE_TAVILY=
TAVILY_API_KEY=

# --- web-tester: selainautomaatio (vapaaehtoinen) -------------------
# Tarvitsee: uv sync + `uv run playwright install chromium`.
# Vision-malli jolla screenshot-action voi kuvailla sivun (qwen-vl OpenRouterissa, ~ilmainen).
#   VISION_MODEL=qwen/qwen3-vl-8b-instruct   (halvin) | qwen/qwen2.5-vl-72b-instruct (vahvin)
VISION_MODEL=qwen/qwen3-vl-30b-a3b-instruct
# Rajaa minne selain saa navigoida (pilkkuerotettu hostlista); tyhjä = salli kaikki.
#   esim. BROWSER_ALLOWED_DOMAINS=aimeat.io
BROWSER_ALLOWED_DOMAINS=

# --- crew-forge: agentti joka tekee agentteja ------------------------
# AIMEAT-tilisi nimi (omistaja). crew-forge rekisteröi tekemänsä agentit
# tällä tilillä:  aimeat connect add ... --owner $AIMEAT_OWNER
# Aseta tämä, jos ajat crews/crew_forge_crew.py:tä.
AIMEAT_OWNER=
