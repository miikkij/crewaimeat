# =====================================================================
# crewaimeat – ympäristömuuttujat. Kopioi tämä tiedostoksi .env ja täytä.
#   cp .env.example .env        (tai Windows: copy .env.example .env)
# =====================================================================

# --- OpenRouter (pakollinen) -----------------------------------------
# Hae avain: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Malli OpenRouterin muodossa "openrouter/<provider>/<model>".
# Halpoja/nopeita vaihtoehtoja PoC:lle:
#   openrouter/x-ai/grok-4-fast              (halpa, nopea – oletus)
#   openrouter/deepseek/deepseek-chat-v3.1   (erittäin halpa)
#   openrouter/google/gemini-2.0-flash-001   (halpa, nopea)
#   openrouter/openai/gpt-4o-mini            (luotettava, hieman kalliimpi)
OPENROUTER_MODEL=openrouter/x-ai/grok-4-fast
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Vapaaehtoinen: lämpötila (0.0 = deterministinen, 1.0 = luova)
LLM_TEMPERATURE=0.5

# --- Vaihtoehto: xAI suoraan (jätä tyhjäksi jos käytät OpenRouteria) --
# Jos haluat ohittaa OpenRouterin ja kutsua xAI:ta suoraan, aseta:
#   USE_XAI=1
#   XAI_API_KEY=xai-...
#   XAI_MODEL=xai/grok-4-fast
USE_XAI=
XAI_API_KEY=
XAI_MODEL=xai/grok-4-fast

# --- Tavily web-haku (vapaaehtoinen mutta suositeltu) ----------------
# Hae avain: https://app.tavily.com/  (ilmainen taso riittää PoC:lle)
# Jos tämä puuttuu, agentit toimivat ilman web-hakua.
TAVILY_API_KEY=

# --- crew-forge: agentti joka tekee agentteja ------------------------
# AIMEAT-tilisi nimi (omistaja). crew-forge rekisteröi tekemänsä agentit
# tällä tilillä:  aimeat connect add ... --owner $AIMEAT_OWNER
# Aseta tämä, jos ajat crews/crew_forge_crew.py:tä.
AIMEAT_OWNER=
