# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
build/
dist/
docs/aimeat-guides
# Salaisuudet
.env
# AIMEAT-konnektorin koti (AIMEAT_HOME): serve.json, agenttitokenit, configit — EI committia
.aimeat/

# Crew-ajojen tulokset (säilytetään kansio, ei tiedostoja)
output/*
!output/.gitkeep

# CrewAI / työkalujen välimuistit
.crewai/
db/
*.log

# Crew-prosessien lokit, README-välimuisti ja fleet-lukko
logs/

# Self-evolution staging — ehdokas-crewit ennen promootiota (ei committaa, ei skannata fleettiin)
crews/.candidates/
# Ignore .claude scratch (ad-hoc scripts, local settings, snapshots) but version-control the
# shared Claude Code agents + skills so the team/next agent inherits the project's conventions.
.claude/*
!.claude/agents/
!.claude/skills/
blueprint_test.json

# user-specific provider/model priority config (the .example is committed)
llm_providers.json
docs/internal/

# LOCOMO benchmark: the dataset is downloaded on demand (provenance printed), not vendored;
# run outputs stay local. (Crew memory stores live under .aimeat/, already ignored above.)
benchmarks/locomo/.data/

# Enterprise "Secretary" agent/agency — PRIVATE. Its own nested git repo + private
# GitHub remote (mirrors the aimeat-protocol `ee/` open-core seam). Never committed
# to this public repo.
/secretary/
.lingua-images/
